{
  "version": 2,
  "builds": [
    { "src": "api/veille.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/veille", "dest": "/api/veille.js" },
    { "src": "/skema-logo.png", "dest": "/public/skema-logo.png" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
